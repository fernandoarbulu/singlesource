            await JS.InvokeVoidAsync("propertyOverview.scrollDetailToTop");
        }
        catch (JSDisconnectedException) { }
        catch { }
    }

    private void RecomputeSearch()
    {
        var q = _fieldSearch?.Trim();
        _searchHits.Clear();
        _searchHitFieldIds.Clear();
        _searchHitsTruncated = false;
        if (string.IsNullOrEmpty(q)) return;

        foreach (var cat in _categories)
        {
            var catMatches = cat.Title.Contains(q, StringComparison.OrdinalIgnoreCase);
            foreach (var sub in cat.Subsections)
            {
                var subMatches = sub.Title.Contains(q, StringComparison.OrdinalIgnoreCase);
                foreach (var field in sub.Fields)
                {
                    if (!ShouldShowField(field)) continue;
                    var fieldLabelMatch = field.Label.Contains(q, StringComparison.OrdinalIgnoreCase);
                    var valueMatch = (field.Value ?? "").Contains(q, StringComparison.OrdinalIgnoreCase);
                    if (!catMatches && !subMatches && !fieldLabelMatch && !valueMatch)
                        continue;

                    var id = FieldDomId(field);
                    _searchHitFieldIds.Add(id);

                    if (_searchHits.Count < SearchHitLimit)
                    {
                        _searchHits.Add(new SearchHit(
                            cat.AnchorId,
                            cat.Title,
                            sub.Key,
                            sub.Title,
                            field.Label,
                            id));
                    }
                    else
                    {
                        _searchHitsTruncated = true;
                    }
                }
            }
        }
    }

    private async Task JumpToHitAsync(SearchHit hit)
    {
        _activeSectionId = hit.AnchorId;
        _selectedSearchFieldId = hit.FieldElementId;
        // Ensure the target subsection is expanded so the field exists in the DOM
        // before OnAfterRenderAsync calls scrollAndHighlightField.
        _expandedSubsections.Add(hit.SubsectionKey);
        _pendingJumpFieldId = hit.FieldElementId; // consumed by OnAfterRenderAsync
        await InvokeAsync(StateHasChanged);
    }

    private void RebuildBreadcrumb()
    {
        _breadcrumbTrail =
        [
            new BreadcrumbLink { Text = "Properties", Url = "/properties/portfolio" },
            new BreadcrumbLink { Text = "Work Orders", Url = "/property-details" },
            new BreadcrumbLink
            {
                Text = _payload?.AddressLine1 ?? "…",
                Url = null,
                Disabled = true
            }
        ];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            RebuildBreadcrumb();
            try
            {
                await Task.Yield();
                var dto = await PropertyDetailsService.GetPropertyDetailsAsync("123-main-st", CancellationToken.None);
                _payload = dto;

                _categories.Clear();
                _categories.AddRange(PropertyMdmCatalog.BuildCategories(PropertyDetailsDtoMapper.ToMdmRoot(dto)));
                if (_categories.Count == 0)
                {
                    _loadError =
                        "Property MDM schema loaded but no categories were built (field categories may be empty).";
                }
                else
                {
                    _loadError = null;
                    _activeSectionId = _categories[0].AnchorId;
                    // Expand the first 2 subsections of every category so top content
                    // is immediately visible; everything else starts collapsed.
                    foreach (var cat in _categories)
                        foreach (var sub in cat.Subsections.Take(2))
                            _expandedSubsections.Add(sub.Key);
                }

                BuildHero(dto);
                RebuildBreadcrumb();
            }
            catch (Exception ex)
            {
                _loadError = $"Could not load property data: {ex}";
                _categories.Clear();
                _heroSummaryGroups.Clear();
                _payload = null;
                RebuildBreadcrumb();
            }
            finally
            {
                _mdmReady = true;
            }

            await InvokeAsync(StateHasChanged);
        }

        // Consume a pending field jump queued by JumpToHitAsync.
        // Running here guarantees the target element exists in the DOM before we
        // call into JS. Latest click always wins — rapid clicks overwrite _pendingJumpFieldId
        // and only the final value is processed when the batched render completes.
        if (_pendingJumpFieldId is { } fieldId)
        {
            _pendingJumpFieldId = null;
            try { await JS.InvokeVoidAsync("propertyOverview.scrollAndHighlightField", fieldId); }
            catch (JSDisconnectedException) { }
            catch { }
        }
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
