@page "/properties/work-orders/123-main-st"
@page "/property-details"
@layout PropertyShellLayout
@implements IAsyncDisposable
@using Telerik.SvgIcons
@inject IJSRuntime JS
@inject IPropertyDetailsService PropertyDetailsService
@using SinglesourceApp.Data
@using SinglesourceApp.Models
@using SinglesourceApp.Services

<PageTitle>@(_payload?.AddressLine1 ?? "Property") — Work Orders</PageTitle>

@* Single root wrapper: .psh-main is a flex column; this column fills height and splits top bar + scrollable body. *@
<div class="pd-route-root">
    <header class="pd-topbar" role="banner">
        <TelerikBreadcrumb Data="@_breadcrumbTrail"
                             TextField="@nameof(BreadcrumbLink.Text)"
                             UrlField="@nameof(BreadcrumbLink.Url)"
                             DisabledField="@nameof(BreadcrumbLink.Disabled)"
                             CollapseMode="@BreadcrumbCollapseMode.Auto"
                             Size="@ThemeConstants.Breadcrumb.Size.Medium"
                             Width="100%"
                             AriaLabel="Breadcrumb" />
    </header>

    <div class="pd-page @(_layoutViewId == 2 ? "pd-page--compact" : null)">

    <TelerikCard Class="pd-hero-card pd-hero-dashboard" ThemeColor="@ThemeConstants.Card.ThemeColor.Light" Width="100%">
        <CardBody Class="pd-hero-card-body">
            <TelerikGridLayout Class="pd-hero-dashboard-grid"
                               RowSpacing="0"
                               ColumnSpacing="32px"
                               Width="100%"
                               HorizontalAlign="@GridLayoutHorizontalAlign.Stretch"
                               VerticalAlign="@GridLayoutVerticalAlign.Top">
                <GridLayoutRows>
                    <GridLayoutRow Height="auto" />
                </GridLayoutRows>
                <GridLayoutColumns>
                    <GridLayoutColumn Width="220px" />
                    <GridLayoutColumn Width="1fr" />
                    <GridLayoutColumn Width="260px" />
                </GridLayoutColumns>
                <GridLayoutItems>
                    <GridLayoutItem Row="1" Column="1">
                        <TelerikCard ThemeColor="@ThemeConstants.Card.ThemeColor.Light" Width="220px" Class="pd-hero-image-card">
                            <CardBody Class="pd-hero-image-body">
                                <TelerikAvatar Type="@AvatarType.Image"
                                               Width="204px"
                                               Height="148px"
                                               Rounded="@ThemeConstants.Avatar.Rounded.Small"
                                               Class="pd-hero-thumb">
                                    <img src="images/property-house-crop.jpg"
                                         alt="Property at @(_payload?.AddressLine1 ?? "this address")"
                                         width="204"
                                         height="148"
                                         loading="lazy" />
                                </TelerikAvatar>
                            </CardBody>
                        </TelerikCard>
                    </GridLayoutItem>
                    <GridLayoutItem Row="1" Column="2">
                        <TelerikStackLayout Orientation="@StackLayoutOrientation.Vertical" Spacing="20px" Class="pd-hero-text-col">
                            <TelerikStackLayout Orientation="@StackLayoutOrientation.Horizontal"
                                                Spacing="14px"
                                                VerticalAlign="@StackLayoutVerticalAlign.Center"
                                                HorizontalAlign="@StackLayoutHorizontalAlign.Stretch">
                                <h1 class="pd-hero-title pd-flex-grow">@(_payload?.AddressLine1 ?? "…")</h1>
                                @if (_payload is not null)
                                {
                                    <TelerikChip Text="@_payload.HeroStatusLabel"
                                                 ThemeColor="@HeroChipTheme(_payload.HeroStatusKind)"
                                                 FillMode="@ThemeConstants.Chip.FillMode.Solid"
                                                 Size="@ThemeConstants.Chip.Size.Small"
                                                 Rounded="@ThemeConstants.Chip.Rounded.Medium"
                                                 Selectable="false" />
                                }
                                else
                                {
                                    <TelerikChip Text="—"
                                                 ThemeColor="@ThemeConstants.Chip.ThemeColor.Base"
                                                 FillMode="@ThemeConstants.Chip.FillMode.Solid"
                                                 Size="@ThemeConstants.Chip.Size.Small"
                                                 Selectable="false" />
                                }
                            </TelerikStackLayout>
                            <p class="pd-hero-sub">@(_payload?.CityStateZip ?? "")</p>
                            @if (_mdmReady)
                            {
                                <TelerikStackLayout Orientation="@StackLayoutOrientation.Horizontal"
                                                    Spacing="22px"
                                                    Class="pd-hero-summary pd-w-full"
                                                    Width="100%"
                                                    HorizontalAlign="@StackLayoutHorizontalAlign.Stretch"
                                                    VerticalAlign="@StackLayoutVerticalAlign.Top">
                                    @foreach (var grp in _heroSummaryGroups)
                                    {
                                        <TelerikStackLayout Orientation="@StackLayoutOrientation.Vertical"
                                                            Spacing="0"
                                                            Class="pd-hero-summary-group pd-flex-grow">
                                            @foreach (var hf in grp.Fields)
                                            {
                                                <div class="pd-data-field">
                                                    <span class="pd-data-field__lbl @(hf.IsKey ? "pd-data-field__lbl--key" : null)">@hf.Label</span>
                                                    <span class="pd-data-field__val @hf.ValueClass @(hf.IsEmpty ? "pd-data-field__val--empty" : null)">@hf.Value</span>
                                                </div>
                                            }
                                        </TelerikStackLayout>
                                    }
                                </TelerikStackLayout>
                            }
                            else
                            {
                                <TelerikLoader Visible="true"
                                               Type="@LoaderType.ConvergingSpinner"
                                               ThemeColor="@ThemeConstants.Loader.ThemeColor.Primary"
                                               Size="@ThemeConstants.Loader.Size.Small" />
                            }
                        </TelerikStackLayout>
                    </GridLayoutItem>
                    <GridLayoutItem Row="1" Column="3">
                        <TelerikCard ThemeColor="@ThemeConstants.Card.ThemeColor.Light" Class="pd-work-orders-card" Width="100%">
                            <CardHeader Class="pd-py-2">
                                <CardTitle Class="pd-wo-title">Work orders</CardTitle>
                            </CardHeader>
                            <CardBody Class="pd-pt-0">
                                <TelerikStackLayout Orientation="@StackLayoutOrientation.Horizontal"
                                                    Spacing="0"
                                                    HorizontalAlign="@StackLayoutHorizontalAlign.Stretch"
                                                    VerticalAlign="@StackLayoutVerticalAlign.Stretch"
                                                    Class="pd-metrics-stack">
                                    <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Flat"
                                                   ThemeColor="@ThemeConstants.Button.ThemeColor.Base"
                                                   Class="pd-metric-btn pd-flex-grow"
                                                   Title="View open work orders"
                                                   OnClick="@(() => SetPrimaryTab("Work Order"))">
                                        <TelerikStackLayout Orientation="@StackLayoutOrientation.Vertical"
                                                            Spacing="4px"
                                                            HorizontalAlign="@StackLayoutHorizontalAlign.Center">
                                            <span class="pd-metric-lbl">Open</span>
                                            <span class="pd-metric-num pd-metric-num--blue">@(_payload?.WorkOrdersSummary.Open ?? 0)</span>
                                        </TelerikStackLayout>
                                    </TelerikButton>
                                    <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Flat"
                                                   ThemeColor="@ThemeConstants.Button.ThemeColor.Base"
                                                   Class="pd-metric-btn pd-flex-grow"
                                                   Title="View billed work orders"
                                                   OnClick="@(() => SetPrimaryTab("Work Order"))">
                                        <TelerikStackLayout Orientation="@StackLayoutOrientation.Vertical"
                                                            Spacing="4px"
                                                            HorizontalAlign="@StackLayoutHorizontalAlign.Center">
                                            <span class="pd-metric-lbl">Billed</span>
                                            <span class="pd-metric-num pd-metric-num--navy">@(_payload?.WorkOrdersSummary.Billed ?? 0)</span>
                                        </TelerikStackLayout>
                                    </TelerikButton>
                                    <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Flat"
                                                   ThemeColor="@ThemeConstants.Button.ThemeColor.Base"
                                                   Class="pd-metric-btn pd-flex-grow"
                                                   Title="View cancelled work orders"
                                                   OnClick="@(() => SetPrimaryTab("Work Order"))">
                                        <TelerikStackLayout Orientation="@StackLayoutOrientation.Vertical"
                                                            Spacing="4px"
                                                            HorizontalAlign="@StackLayoutHorizontalAlign.Center">
                                            <span class="pd-metric-lbl">Cancelled</span>
                                            <span class="pd-metric-num pd-metric-num--muted">@(_payload?.WorkOrdersSummary.Cancelled ?? 0)</span>
                                        </TelerikStackLayout>
                                    </TelerikButton>
                                </TelerikStackLayout>
                            </CardBody>
                        </TelerikCard>
                    </GridLayoutItem>
                </GridLayoutItems>
            </TelerikGridLayout>
            <TelerikStackLayout Orientation="@StackLayoutOrientation.Horizontal"
                                HorizontalAlign="@StackLayoutHorizontalAlign.Right"
                                VerticalAlign="@StackLayoutVerticalAlign.Center"
                                Class="pd-hero-actions">
                <TelerikButton Icon="@SvgIcon.ChevronDown"
                               FillMode="@ThemeConstants.Button.FillMode.Flat"
                               ThemeColor="@ThemeConstants.Button.ThemeColor.Base"
                               AriaLabel="More actions"
                               Title="More actions" />
            </TelerikStackLayout>
        </CardBody>
    </TelerikCard>

    <TelerikGridLayout Class="pd-tab-toolbar pd-w-full"
                       RowSpacing="12px"
                       ColumnSpacing="20px"
                       Width="100%">
        <GridLayoutRows>
            <GridLayoutRow Height="auto" />
        </GridLayoutRows>
        <GridLayoutColumns>
            <GridLayoutColumn Width="1fr" />
            <GridLayoutColumn Width="160px" />
        </GridLayoutColumns>
        <GridLayoutItems>
            <GridLayoutItem Row="1" Column="1">
                <TelerikTabStrip @bind-ActiveTabIndex="@_activePrimaryTabIndex"
                                 Class="pd-tabstrip"
                                 Width="100%"
                                 Scrollable="true"
                                 PersistTabContent="true"
                                 TabAlignment="@TabStripTabAlignment.Start"
                                 Size="@ThemeConstants.TabStrip.Size.Medium">
                    @for (var i = 0; i < _primaryTabs.Length; i++)
                    {
                        var idx = i;
                        var title = _primaryTabs[i];
                        <TabStripTab Title="@title">
                            @if (idx == 0)
                            {
                                @if (_loadError is not null)
                                {
                                    <TelerikCard ThemeColor="@ThemeConstants.Card.ThemeColor.Error" Class="pd-load-error pd-mt-1">
                                        <CardBody Class="pd-load-error-body" role="alert">
                                            @_loadError
                                        </CardBody>
                                    </TelerikCard>
                                }
                                else if (!_mdmReady)
                                {
                                    <TelerikStackLayout Orientation="@StackLayoutOrientation.Horizontal"
                                                        Spacing="12px"
                                                        VerticalAlign="@StackLayoutVerticalAlign.Center"
                                                        Class="pd-mdm-loading">
                                        <TelerikLoader Visible="true"
                                                       Type="@LoaderType.ConvergingSpinner"
                                                       ThemeColor="@ThemeConstants.Loader.ThemeColor.Primary"
                                                       Size="@ThemeConstants.Loader.Size.Medium" />
                                        <span class="pd-mdm-loading-text" role="status">Loading property fields…</span>
                                    </TelerikStackLayout>
                                }
                                else
                                {
                                    <TelerikSplitter Class="pd-splitter pd-mt-3"
                                                     Orientation="@SplitterOrientation.Horizontal"
                                                     Width="100%"
                                                     AriaLabel="Property details">
                                        <SplitterPanes>
                                            <SplitterPane Size="288px" Min="200px" Collapsible="true" Scrollable="true" Class="pd-split-pane-nav">
                                                <TelerikStackLayout Orientation="@StackLayoutOrientation.Vertical" Spacing="14px" Class="pd-nav-stack">
                                                    <TelerikFloatingLabel Text="Search fields"
                                                                          Class="pd-field-search-fl">
                                                        <TelerikTextBox Id="pd-field-search"
                                                                        Value="@_fieldSearch"
                                                                        ValueChanged="@OnFieldSearchChanged"
                                                                        Placeholder=" "
                                                                        Width="100%" />
                                                    </TelerikFloatingLabel>
                                                    @if (_searchHits.Count > 0 && !string.IsNullOrWhiteSpace(_fieldSearch))
                                                    {
                                                        <TelerikGrid TItem="SearchHit"
                                                                     Data="@_searchHits.Take(20).ToList()"
                                                                     Pageable="false"
                                                                     Sortable="false"
                                                                     Height="220px"
                                                                     OnRowClick="@OnSearchHitRowClick"
                                                                     Class="pd-search-hit-grid pd-w-full">
                                                            <GridColumns>
                                                                <GridColumn Title="Match">
                                                                    <Template>
                                                                        @{
                                                                            var hit = (SearchHit)context;
                                                                        }
                                                                        <div class="pd-data-field pd-data-field--compact">
                                                                            <span class="pd-data-field__lbl">@hit.FieldLabel</span>
                                                                            <span class="pd-data-field__val pd-data-field__meta">@hit.CategoryTitle · @hit.SubsectionTitle</span>
                                                                        </div>
                                                                    </Template>
                                                                </GridColumn>
                                                            </GridColumns>
                                                        </TelerikGrid>
                                                    }
                                                    <TelerikGrid TItem="PropertyMdmCategoryVm"
                                                                 Data="@_categories"
                                                                 Pageable="false"
                                                                 Sortable="false"
                                                                 Height="380px"
                                                                 OnRowClick="@OnCategoryRowClick"
                                                                 OnRowRender="@OnCategoryRowRender"
                                                                 Class="pd-category-grid pd-w-full">
                                                        <GridColumns>
                                                            <GridColumn Field="@nameof(PropertyMdmCategoryVm.Title)" Title="Sections" />
                                                        </GridColumns>
                                                    </TelerikGrid>
                                                </TelerikStackLayout>
                                            </SplitterPane>
                                            <SplitterPane Scrollable="true" Class="pd-split-pane-detail">
                                                @{
                                                    var active = _categories.FirstOrDefault(c => c.AnchorId == _activeSectionId);
                                                }
                                                @if (active is not null)
                                                {
                                                    <TelerikCard @key="@($"hdr-{_activeSectionId}")"
                                                                 Class="pd-inspector-card"
                                                                 ThemeColor="@ThemeConstants.Card.ThemeColor.Light"
                                                                 Width="100%">
                                                        <CardHeader Class="pd-insp-header">
                                                            <TelerikGridLayout ColumnSpacing="12px"
                                                                               RowSpacing="0"
                                                                               Width="100%">
                                                                <GridLayoutRows>
                                                                    <GridLayoutRow Height="auto" />
                                                                </GridLayoutRows>
                                                                <GridLayoutColumns>
                                                                    <GridLayoutColumn Width="1fr" />
                                                                    <GridLayoutColumn Width="auto" />
                                                                </GridLayoutColumns>
                                                                <GridLayoutItems>
                                                                    <GridLayoutItem Row="1" Column="1">
                                                                        <CardTitle Class="pd-insp-title">@active.Title</CardTitle>
                                                                    </GridLayoutItem>
                                                                    <GridLayoutItem Row="1" Column="2">
                                                                        <TelerikSwitch @bind-Value="@_clientFields"
                                                                                       OnLabel="Client fields"
                                                                                       OffLabel="Client fields"
                                                                                       Width="auto" />
                                                                    </GridLayoutItem>
                                                                </GridLayoutItems>
                                                            </TelerikGridLayout>
                                                        </CardHeader>
                                                        <CardBody Class="pd-insp-body">
                                                            <div class="pd-mdm-subgrid">
                                                                @{
                                                                    var subsectionList = active.Subsections.ToList();
                                                                }
                                                                @for (var si = 0; si < subsectionList.Count; si++)
                                                                {
                                                                    var sub = subsectionList[si];
                                                                    var visibleInSub = sub.Fields.Where(ShouldShowField).ToList();
                                                                    var spanDenseFull = ShouldSubsectionSpanFullWidth(subsectionList, si, visibleInSub.Count);
                                                                    <TelerikCard @key="@($"{_activeSectionId}-{sub.Key}")"
                                                                                 Class="@($"pd-mdm-subcard{(spanDenseFull ? " pd-mdm-subcard--span-full" : "")}")"
                                                                                 ThemeColor="@ThemeConstants.Card.ThemeColor.Light"
                                                                                 Width="100%">
                                                                        <CardHeader Class="pd-mdm-subhead">
                                                                            <CardTitle Class="pd-mdm-subtitle">@sub.Title</CardTitle>
                                                                        </CardHeader>
                                                                        <CardBody Class="pd-mdm-subbody">
                                                                            <TelerikGrid TItem="PropertyMdmFieldJson"
                                                                                         Data="@visibleInSub"
                                                                                         Pageable="false"
                                                                                         Sortable="false"
                                                                                         Resizable="false"
                                                                                         OnRowRender="@OnFieldRowRender"
                                                                                         Class="pd-mdm-field-grid pd-w-full">
                                                                                <GridColumns>
                                                                                    <GridColumn Title="">
                                                                                        <Template>
                                                                                            @{
                                                                                                var f = (PropertyMdmFieldJson)context;
                                                                                            }
                                                                                            <div class="pd-data-field" id="@FieldDomId(f)">
                                                                                                <span class="pd-data-field__lbl">@f.Label</span>
                                                                                                @if (f.Kind == "textarea")
                                                                                                {
                                                                                                    <div class="pd-data-field__val pd-data-field__val--multiline">@FormatDisplay(f)</div>
                                                                                                }
                                                                                                else
                                                                                                {
                                                                                                    <div class="pd-data-field__val">@FormatDisplay(f)</div>
                                                                                                }
                                                                                            </div>
                                                                                        </Template>
                                                                                    </GridColumn>
                                                                                </GridColumns>
                                                                            </TelerikGrid>
                                                                        </CardBody>
                                                                    </TelerikCard>
                                                                }
                                                            </div>
                                                        </CardBody>
                                                    </TelerikCard>
                                                }
                                            </SplitterPane>
                                        </SplitterPanes>
                                    </TelerikSplitter>
                                }
                            }
                            else
                            {
                                <TelerikCard Class="pd-tab-placeholder pd-mt-3" ThemeColor="@ThemeConstants.Card.ThemeColor.Light">
                                    <CardBody Class="pd-tab-placeholder-body">
                                        <p class="pd-tab-placeholder-text">This section is not available in the prototype shell. Content will appear here when the workflow is connected.</p>
                                    </CardBody>
                                </TelerikCard>
                            }
                        </TabStripTab>
                    }
                </TelerikTabStrip>
            </GridLayoutItem>
            <GridLayoutItem Row="1" Column="2">
                <TelerikStackLayout Orientation="@StackLayoutOrientation.Vertical"
                                    Spacing="6px"
                                    Class="pd-layout-stack"
                                    HorizontalAlign="@StackLayoutHorizontalAlign.Stretch">
                    <label class="pd-field-label" for="pd-layout-view">Layout</label>
                    <TelerikDropDownList Id="pd-layout-view"
                                         Data="@_layoutViewOptions"
                                         @bind-Value="@_layoutViewId"
                                         TextField="@nameof(LayoutViewOption.Name)"
                                         ValueField="@nameof(LayoutViewOption.Id)"
                                         Width="100%"
                                         Class="pd-layout-ddl" />
                </TelerikStackLayout>
            </GridLayoutItem>
        </GridLayoutItems>
    </TelerikGridLayout>
    </div>
</div>

@code {
    private readonly string[] _primaryTabs =
    [
        "Overview", "Tasks", "Work Order", "Bids", "Conveyance", "Financials", "Photos", "Files", "Audit"
    ];

    private int _activePrimaryTabIndex;

    private readonly List<PropertyMdmCategoryVm> _categories = [];

    private string? _loadError;

    private bool _mdmReady;

    private string _activeSectionId = "pd-overview";

    private string? _fieldSearch;

    private readonly List<SearchHit> _searchHits = [];

    private string? _pendingFieldId;

    private string? _flashFieldId;

    private DotNetObjectReference<PropertyWorkOrderDetails>? _dotNetRef;

    private bool _clientFields = true;

    private int _layoutViewId = 1;

    private readonly List<LayoutViewOption> _layoutViewOptions =
    [
        new LayoutViewOption(1, "Default"),
        new LayoutViewOption(2, "Compact")
    ];

    private List<BreadcrumbLink> _breadcrumbTrail = [];

    private sealed record LayoutViewOption(int Id, string Name);

    private sealed class BreadcrumbLink
    {
        public string Text { get; set; } = "";
        public string? Url { get; set; }
        public bool Disabled { get; set; }
    }

    private sealed record SearchHit(
        string AnchorId,
        string CategoryTitle,
        string SubsectionKey,
        string SubsectionTitle,
        string FieldLabel,
        string FieldElementId);

    private sealed record HeroField(string Label, string Value, bool IsKey = false, string ValueClass = "", bool IsEmpty = false);

    private sealed record HeroSummaryGroup(string Title, IReadOnlyList<HeroField> Fields);

    private readonly List<HeroSummaryGroup> _heroSummaryGroups = [];

    private static readonly (string Title, string[] Labels)[] HeroGroupOrder =
    [
        ("Status", ["Loan status", "Occupancy", "Days delinquent"]),
        ("Financial", ["Loan type", "UPB", "Investor"]),
        ("Meta", ["Last inspection", "APN"])
    ];

    private PropertyDetailsDto? _payload;

    private Task OnFieldSearchChanged(string v)
    {
        _fieldSearch = v;
        RecomputeSearch();
        return Task.CompletedTask;
    }

    private void OnCategoryRowRender(GridRowRenderEventArgs args)
    {
        if (args.Item is PropertyMdmCategoryVm c)
        {
            if (c.AnchorId == _activeSectionId)
                args.Class = "pd-grid-row-active";
        }
    }

    private void OnFieldRowRender(GridRowRenderEventArgs args)
    {
        if (args.Item is not PropertyMdmFieldJson f)
            return;
        var id = FieldDomId(f);
        var q = _fieldSearch?.Trim();
        var isHit = !string.IsNullOrEmpty(q) &&
                    (f.Label.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                     (f.Value ?? "").Contains(q, StringComparison.OrdinalIgnoreCase));
        var parts = new List<string>();
        if (isHit)
            parts.Add("pd-field-row--hit");
        if (_flashFieldId == id)
            parts.Add("pd-field-row--flash");
        if (parts.Count > 0)
            args.Class = string.Join(' ', parts);
    }

    private void OnCategoryRowClick(GridRowClickEventArgs args)
    {
        if (args.Item is not PropertyMdmCategoryVm cat)
            return;
        SelectSection(cat.AnchorId);
    }

    private async Task OnSearchHitRowClick(GridRowClickEventArgs args)
    {
        if (args.Item is not SearchHit hit)
            return;
        await JumpToHitAsync(hit);
    }

    private static string HeroChipTheme(string? kind)
    {
        if (string.IsNullOrWhiteSpace(kind))
            return ThemeConstants.Chip.ThemeColor.Base;
        if (string.Equals(kind, "success", StringComparison.OrdinalIgnoreCase))
            return ThemeConstants.Chip.ThemeColor.Success;
        return kind.ToLowerInvariant() switch
        {
            "active" => ThemeConstants.Chip.ThemeColor.Success,
            "inactive" => ThemeConstants.Chip.ThemeColor.Error,
            "pending" => ThemeConstants.Chip.ThemeColor.Warning,
            "neutral" => ThemeConstants.Chip.ThemeColor.Base,
            _ => ThemeConstants.Chip.ThemeColor.Base
        };
    }

    private void BuildHero(PropertyDetailsDto dto)
    {
        _heroSummaryGroups.Clear();
        var keyLabels = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "Loan status",
            "Occupancy",
            "Days delinquent",
            "Loan type",
            "UPB",
            "Last inspection"
        };
        var valueClassByLabel = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Loan status"] = "pd-hero-v--status",
            ["UPB"] = "pd-hero-v--hero-currency",
            ["Last inspection"] = "pd-hero-v--hero-date"
        };

        var byLabel = new Dictionary<string, HeroField>(StringComparer.OrdinalIgnoreCase);
        foreach (var f in dto.HeroSummaryFields)
        {
            var empty = string.IsNullOrWhiteSpace(f.Value);
            var display = empty ? "—" : f.Value!;
            var label = f.Label;
            var isKey = keyLabels.Contains(label);
            valueClassByLabel.TryGetValue(label, out var vc);
            vc ??= "";
            byLabel[label] = new HeroField(Label: label, Value: display, IsKey: isKey, ValueClass: vc, IsEmpty: empty);
        }

        foreach (var (title, labels) in HeroGroupOrder)
        {
            var fields = new List<HeroField>(labels.Length);
            foreach (var lbl in labels)
            {
                if (byLabel.TryGetValue(lbl, out var hf))
                    fields.Add(hf);
            }

            _heroSummaryGroups.Add(new HeroSummaryGroup(title, fields));
        }
    }

    private static string FieldDomId(PropertyMdmFieldJson f) => $"pd-mdm-{f.Id}";

    private bool ShouldShowField(PropertyMdmFieldJson f)
    {
        if (string.Equals(f.Visibility, "clientSpecific", StringComparison.OrdinalIgnoreCase) && !_clientFields)
            return false;
        return true;
    }

    private int CountVisibleFields(PropertyMdmSubsectionVm sub) =>
        sub.Fields.Count(ShouldShowField);

    /// <summary>Full-width subsection card when visibly denser than both neighbors (readability in 2-col grid).</summary>
    private bool ShouldSubsectionSpanFullWidth(IReadOnlyList<PropertyMdmSubsectionVm> subs, int index, int visibleCount)
    {
        if (visibleCount < 8) return false;
        var leftN = index > 0 ? CountVisibleFields(subs[index - 1]) : 0;
        var rightN = index < subs.Count - 1 ? CountVisibleFields(subs[index + 1]) : 0;
        var maxNeighbor = Math.Max(leftN, rightN);
        if (maxNeighbor == 0) return visibleCount >= 12;
        return visibleCount >= maxNeighbor * 2;
    }

    private static string FormatDisplay(PropertyMdmFieldJson f)
    {
        var v = f.Value;
        if (string.IsNullOrWhiteSpace(v))
            return "—";
        return v;
    }

    private void SetPrimaryTab(string tab)
    {
        var idx = Array.IndexOf(_primaryTabs, tab);
        if (idx >= 0)
            _activePrimaryTabIndex = idx;
    }

    private void SelectSection(string anchorId)
    {
        if (_activeSectionId == anchorId) return;
        _flashFieldId = null;
        _searchHits.Clear();
        _activeSectionId = anchorId;
    }

    private void RecomputeSearch()
    {
        var q = _fieldSearch?.Trim();
        _searchHits.Clear();
        if (string.IsNullOrEmpty(q)) return;

        foreach (var cat in _categories)
        {
            foreach (var sub in cat.Subsections)
            {
                foreach (var field in sub.Fields)
                {
                    if (!ShouldShowField(field)) continue;
                    if (field.Label.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                        (field.Value ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
                    {
                        _searchHits.Add(new SearchHit(
                            cat.AnchorId,
                            cat.Title,
                            sub.Key,
                            sub.Title,
                            field.Label,
                            FieldDomId(field)));
                    }
                }
            }
        }
    }

    private async Task JumpToHitAsync(SearchHit hit)
    {
        _searchHits.Clear();
        _activeSectionId = hit.AnchorId;
        _pendingFieldId = hit.FieldElementId;
        _flashFieldId = hit.FieldElementId;
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void ClearFlashField()
    {
        if (_flashFieldId is null) return;
        _flashFieldId = null;
        _ = InvokeAsync(StateHasChanged);
    }

    private void RebuildBreadcrumb()
    {
        _breadcrumbTrail =
        [
            new BreadcrumbLink { Text = "Properties", Url = "/properties/portfolio" },
            new BreadcrumbLink { Text = "Work Orders", Url = "/property-details" },
            new BreadcrumbLink
            {
                Text = _payload?.AddressLine1 ?? "…",
                Url = null,
                Disabled = true
            }
        ];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            RebuildBreadcrumb();
            try
            {
                await Task.Yield();
                var dto = await PropertyDetailsService.GetPropertyDetailsAsync("123-main-st", CancellationToken.None);
                _payload = dto;

                _categories.Clear();
                _categories.AddRange(PropertyMdmCatalog.BuildCategories(PropertyDetailsDtoMapper.ToMdmRoot(dto)));
                if (_categories.Count == 0)
                {
                    _loadError =
                        "Property MDM schema loaded but no categories were built (field categories may be empty).";
                }
                else
                {
                    _loadError = null;
                    _activeSectionId = _categories[0].AnchorId;
                }

                BuildHero(dto);
                RebuildBreadcrumb();
            }
            catch (Exception ex)
            {
                _loadError = $"Could not load property data: {ex}";
                _categories.Clear();
                _heroSummaryGroups.Clear();
                _payload = null;
                RebuildBreadcrumb();
            }
            finally
            {
                _mdmReady = true;
            }

            await InvokeAsync(StateHasChanged);
        }

        if (_pendingFieldId is not null)
        {
            var fieldId = _pendingFieldId;
            _pendingFieldId = null;
            await Task.Delay(80);
            try
            {
                await JS.InvokeVoidAsync("propertyOverview.scrollToField", fieldId, _dotNetRef);
            }
            catch (JSDisconnectedException) { }
            catch { }
        }
    }

    public ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        _dotNetRef = null;
        return ValueTask.CompletedTask;
    }
}
