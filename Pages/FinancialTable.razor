@page "/properties/financials"
@layout PropertyShellLayout
@using SinglesourceApp.Components
@using System.Globalization

<PageTitle>Financial Table — 5426 Trinity St</PageTitle>

<div class="pd-route-root">
    <header class="pd-topbar" role="banner">
        <TelerikBreadcrumb Data="@_breadcrumb"
                           TextField="@nameof(BreadcrumbItem.Text)"
                           UrlField="@nameof(BreadcrumbItem.Url)"
                           DisabledField="@nameof(BreadcrumbItem.Disabled)"
                           CollapseMode="@BreadcrumbCollapseMode.Auto"
                           Size="@ThemeConstants.Breadcrumb.Size.Medium"
                           Width="100%"
                           AriaLabel="Breadcrumb" />
    </header>

    <div class="pd-page ft-page">

        @* ── Page header ─────────────────────────────────────────────────────────── *@
        <div class="ft-page-header">
            <div class="ft-page-header__left">
                <h1 class="ft-page-title">Financial Table</h1>
                <p class="ft-page-desc">Read-only property-level financial overview. Line items are grouped by work order. All status changes occur within tasks.</p>
            </div>
            <div class="ft-page-header__right">
                <span class="ft-read-only-badge">Read-only</span>
            </div>
        </div>

        @* ── P&P Summary Panel ────────────────────────────────────────────────────── *@
        <TelerikCard Class="ft-summary-card" ThemeColor="@ThemeConstants.Card.ThemeColor.Light" Width="100%">
            <CardBody>
                <div class="ft-summary-band">

                    @* Property *@
                    <div class="ft-sb-prop">
                        <span class="ft-sb__label">Property</span>
                        <span class="ft-sb__prop-name">@_summary.PropertyAddress</span>
                    </div>

                    <div class="ft-sb-divider" aria-hidden="true"></div>

                    @* P&P group *@
                    <div class="ft-sb-group">
                        <span class="ft-sb__group-heading">P&amp;P</span>
                        <div class="ft-sb-group__fields">
                            <div class="ft-sbf">
                                <span class="ft-sbf__lbl">P&amp;P total</span>
                                <span class="ft-sbf__val ft-sbf__val--em">@Fmt(_summary.PandPTotal)</span>
                            </div>
                            <div class="ft-sbf">
                                <span class="ft-sbf__lbl">Prior</span>
                                <span class="ft-sbf__val">@Fmt(_summary.PandPPrior)</span>
                            </div>
                            <div class="ft-sbf">
                                <span class="ft-sbf__lbl">Current</span>
                                <span class="ft-sbf__val">@Fmt(_summary.PandPCurrent)</span>
                            </div>
                        </div>
                    </div>

                    <div class="ft-sb-divider" aria-hidden="true"></div>

                    @* Reimbursements group *@
                    <div class="ft-sb-group">
                        <span class="ft-sb__group-heading">Reimbursements</span>
                        <div class="ft-sb-group__fields">
                            <div class="ft-sbf">
                                <span class="ft-sbf__lbl">HUD reimb. non-P&amp;P</span>
                                <span class="ft-sbf__val">@Fmt(_summary.HudReimbNonPandP)</span>
                            </div>
                            <div class="ft-sbf">
                                <span class="ft-sbf__lbl">Non-HUD reimb.</span>
                                <span class="ft-sbf__val">@Fmt(_summary.NonHudReimb)</span>
                            </div>
                        </div>
                    </div>

                    <div class="ft-sb-divider" aria-hidden="true"></div>

                    @* Financials group *@
                    <div class="ft-sb-group">
                        <span class="ft-sb__group-heading">Financials</span>
                        <div class="ft-sb-group__fields">
                            <div class="ft-sbf">
                                <span class="ft-sbf__lbl">Total</span>
                                <span class="ft-sbf__val ft-sbf__val--em">@Fmt(_summary.Total)</span>
                            </div>
                            <div class="ft-sbf">
                                <span class="ft-sbf__lbl">Receivables (AR)</span>
                                <span class="ft-sbf__val">@Fmt(_summary.Receivables)</span>
                            </div>
                            <div class="ft-sbf">
                                <span class="ft-sbf__lbl">Payables (AP)</span>
                                <span class="ft-sbf__val">@Fmt(_summary.Payables)</span>
                            </div>
                        </div>
                    </div>

                    <div class="ft-sb-divider" aria-hidden="true"></div>

                    @* Pending approvals *@
                    <div class="ft-sb-pending">
                        <span class="ft-sb__label">Pending approvals</span>
                        <span class="ft-pending-pill">@_summary.PendingApprovals</span>
                    </div>

                </div>
            </CardBody>
        </TelerikCard>

        @* ── Financial Line Item Table ─────────────────────────────────────────────── *@
        @*
            Implementation note: TelerikGrid RowTemplate does not support <td colspan="N">
            spanning all defined columns — the grid validates cell count against column
            definitions and throws a runtime error when counts mismatch (WO header, subtotal,
            and total rows all need colspan). A native HTML <table> inside a TelerikCard
            is the correct Telerik-compatible approach for this mixed-row-type display.
        *@
        <TelerikCard Class="ft-table-card" ThemeColor="@ThemeConstants.Card.ThemeColor.Light" Width="100%">
            <CardBody>
                <div class="ft-table-wrap">
                    <table class="ft-table" aria-label="Financial line items grouped by work order">

                        @* ── Column widths (total ≈ 1478px) ── *@
                        <colgroup>
                            <col style="width:130px">  @* Line item *@
                            <col style="width:195px">  @* Description *@
                            <col style="width:50px">   @* Qty *@
                            <col style="width:52px">   @* UOM *@
                            <col style="width:113px">  @* Vendor unit price *@
                            <col style="width:113px">  @* Vendor line total *@
                            <col style="width:84px">   @* Vendor GPID *@
                            <col style="width:107px">  @* Client price *@
                            <col style="width:113px">  @* Client line total *@
                            <col style="width:84px">   @* Client GPID *@
                            <col style="width:98px">   @* Bid ref. amt *@
                            <col style="width:113px">  @* Business (B) *@
                            <col style="width:113px">  @* Customer (C) *@
                            <col style="width:113px">  @* Investor (I) *@
                        </colgroup>

                        @* ── Header row ── *@
                        <thead>
                            <tr class="ft-thead-row">
                                <th scope="col" class="ft-th">Line item</th>
                                <th scope="col" class="ft-th">Description</th>
                                <th scope="col" class="ft-th ft-th-num">Qty</th>
                                <th scope="col" class="ft-th ft-th-center">UOM</th>
                                <th scope="col" class="ft-th ft-th-num">Vendor unit price</th>
                                <th scope="col" class="ft-th ft-th-num">Vendor line total</th>
                                <th scope="col" class="ft-th ft-th-center">Vendor GPID</th>
                                <th scope="col" class="ft-th ft-th-num">Client price</th>
                                <th scope="col" class="ft-th ft-th-num">Client line total</th>
                                <th scope="col" class="ft-th ft-th-center">Client GPID</th>
                                <th scope="col" class="ft-th ft-th-num">Bid ref. amt</th>
                                <th scope="col" class="ft-th">Business (B)</th>
                                <th scope="col" class="ft-th">Customer (C)</th>
                                <th scope="col" class="ft-th">Investor (I)</th>
                            </tr>
                        </thead>

                        @* ── Data rows — all row types rendered in a single pass ── *@
                        @*
                            Variables cannot be declared with @{} inside @foreach/@if bodies in Blazor Razor.
                            All per-row values are computed inline via single-purpose helper methods.
                        *@
                        <tbody>
                            @foreach (var row in VisibleRows)
                            {
                                @* Work Order group header *@
                                @if (row.Kind == FinancialRowKind.WorkOrderHeader)
                                {
                                    <tr class="ft-row-wo-hdr">
                                        <td colspan="14" class="ft-cell-wo-hdr">
                                            <div class="ft-wo-hdr-layout">
                                                <button type="button"
                                                        class="ft-wo-toggle"
                                                        @onclick="@(() => ToggleWorkOrder(row.WorkOrderId ?? ""))"
                                                        title="@(IsCollapsed(row.WorkOrderId) ? "Expand work order" : "Collapse work order")"
                                                        aria-label="@(IsCollapsed(row.WorkOrderId) ? "Expand work order " + row.WorkOrderId : "Collapse work order " + row.WorkOrderId)"
                                                        aria-expanded="@(IsCollapsed(row.WorkOrderId) ? "false" : "true")">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                                         stroke="currentColor" stroke-width="2.5"
                                                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                                                         class="@(IsCollapsed(row.WorkOrderId) ? "ft-wo-chev ft-wo-chev--up" : "ft-wo-chev")">
                                                        <path d="M6 9l6 6 6-6" />
                                                    </svg>
                                                </button>
                                                <div class="ft-wo-hdr-meta">
                                                    @* Primary: WO ID + Category — first-glance scan targets *@
                                                    <div class="ft-wo-primary">
                                                        <span class="ft-wo-id">@row.WorkOrderId</span>
                                                        <span class="ft-wo-sep" aria-hidden="true">·</span>
                                                        <span class="ft-wo-category">@row.Category</span>
                                                    </div>
                                                    @* Secondary: vendor + billed — supporting context *@
                                                    <div class="ft-wo-secondary">
                                                        <span class="ft-wo-vendor">@row.Vendor</span>
                                                        <span class="ft-wo-sep" aria-hidden="true">·</span>
                                                        <span class="ft-wo-billed">Billed @row.BilledDate</span>
                                                    </div>
                                                </div>
                                                @if (IsCollapsed(row.WorkOrderId))
                                                {
                                                    <span class="ft-wo-collapsed-hint">@row.CollapsedHint</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }

                                @* Work Order subtotal *@
                                else if (row.Kind == FinancialRowKind.Subtotal)
                                {
                                    <tr class="ft-row-subtotal">
                                        <td colspan="4" class="ft-cell-subtotal ft-cell-subtotal-lbl">@row.SubtotalLabel subtotal</td>
                                        <td class="ft-cell-subtotal ft-cell-num">@FmtOpt(row.VendorUnitPriceSubtotal)</td>
                                        <td class="ft-cell-subtotal ft-cell-num">@FmtOpt(row.VendorLineTotalSubtotal)</td>
                                        <td class="ft-cell-subtotal"></td>
                                        <td class="ft-cell-subtotal ft-cell-num">@FmtOpt(row.ClientPriceSubtotal)</td>
                                        <td class="ft-cell-subtotal ft-cell-num">@FmtOpt(row.ClientLineTotalSubtotal)</td>
                                        <td class="ft-cell-subtotal" colspan="5"></td>
                                    </tr>
                                }

                                @* Property total *@
                                else if (row.Kind == FinancialRowKind.Total)
                                {
                                    <tr class="ft-row-total">
                                        <td colspan="4" class="ft-cell-total ft-cell-total-lbl">PROPERTY TOTAL (all work orders)</td>
                                        <td class="ft-cell-total ft-cell-num">@FmtOpt(row.VendorUnitPriceSubtotal)</td>
                                        <td class="ft-cell-total ft-cell-num">@FmtOpt(row.VendorLineTotalSubtotal)</td>
                                        <td class="ft-cell-total"></td>
                                        <td class="ft-cell-total ft-cell-num">@FmtOpt(row.ClientPriceSubtotal)</td>
                                        <td class="ft-cell-total ft-cell-num">@FmtOpt(row.ClientLineTotalSubtotal)</td>
                                        <td class="ft-cell-total" colspan="5"></td>
                                    </tr>
                                }

                                @* Line item *@
                                else
                                {
                                    <tr class="ft-row-line">
                                        <td class="ft-cell-data ft-cell-lineitem">@row.LineItem</td>
                                        <td class="ft-cell-data ft-cell-desc">@row.Description</td>
                                        <td class="ft-cell-data ft-cell-num">@row.QtyDisplay</td>
                                        <td class="ft-cell-data ft-cell-uom">@row.Uom</td>
                                        <td class="ft-cell-data ft-cell-num">@FmtOpt(row.VendorUnitPrice)</td>
                                        <td class="ft-cell-data ft-cell-num">@FmtOpt(row.VendorLineTotal)</td>
                                        <td class="ft-cell-data ft-cell-gpid">@(row.VendorGpid ?? "—")</td>
                                        <td class="ft-cell-data ft-cell-num">@FmtOpt(row.ClientPrice)</td>
                                        <td class="ft-cell-data ft-cell-num">@FmtOpt(row.ClientLineTotal)</td>
                                        <td class="ft-cell-data ft-cell-gpid">@(row.ClientGpid ?? "—")</td>
                                        <td class="ft-cell-data ft-cell-num">@FmtOpt(row.BidRefAmt)</td>
                                        <td class="ft-cell-data ft-cell-status"><span class="@StatusCss(row.StatusBusiness)">@StatusText(row.StatusBusiness)</span></td>
                                        <td class="ft-cell-data ft-cell-status"><span class="@StatusCss(row.StatusCustomer)">@StatusText(row.StatusCustomer)</span></td>
                                        <td class="ft-cell-data ft-cell-status"><span class="@StatusCss(row.StatusInvestor)">@StatusText(row.StatusInvestor)</span></td>
                                    </tr>
                                }
                            }
                        </tbody>

                    </table>
                </div>
            </CardBody>
        </TelerikCard>

    </div>
</div>

@code {
    // ══════════════════════════════════════════════════════════════════════════════
    // Page: Financial Table — MVP (Read-Only)
    //
    // Renders a property-level P&P summary panel and a grouped financial line-item
    // table for a single property. The screen is intentionally read-only; all status
    // changes occur within task workflows on other screens.
    //
    // Data sources
    // ─────────────
    // All data is currently supplied by BuildSummary() and BuildAllRows().
    // Replace those two methods with service/API calls when wiring live data.
    // The view-model shapes (FinancialSummaryVm, FinancialRowVm) are designed to
    // map directly to expected API response shapes with minimal transformation.
    //
    // Table implementation note
    // ──────────────────────────
    // TelerikGrid's RowTemplate enforces a fixed cell count matching the defined
    // GridColumns. WO group headers, subtotals, and the property total all require
    // a full-width colspan — this causes a runtime InvalidOperationException inside
    // TelerikGrid. A native HTML <table> inside TelerikCard is the correct
    // Telerik-compatible pattern for mixed-row-type tables. See:
    //   https://docs.telerik.com/blazor-ui/components/grid/templates/row
    //
    // Future scope (intentionally excluded from MVP)
    // ───────────────────────────────────────────────
    // · Adjusted price column  · Variance $ / % columns  · Transaction date
    // · Coverage gap           · Write-offs              · Supplemental submissions
    // · Needs Correction task view
    // ══════════════════════════════════════════════════════════════════════════════

    // ──────────────────────────────────────────────────────────────────────────────
    // Types
    // ──────────────────────────────────────────────────────────────────────────────

    private enum FinancialRowKind { WorkOrderHeader, LineItem, Subtotal, Total }

    /// <summary>
    /// Flat view-model covering all row types in the financial table.
    /// Properties not used by a given row kind remain null / default.
    /// Replace BuildAllRows() with an API/service call to wire live data.
    /// </summary>
    private sealed record FinancialRowVm(
        FinancialRowKind Kind,
        // ── Line item fields ──────────────────────────────────────────────────
        string? LineItem         = null,
        string? Description      = null,
        string? QtyDisplay       = null,
        string? Uom              = null,
        decimal? VendorUnitPrice = null,
        decimal? VendorLineTotal = null,
        string? VendorGpid       = null,
        decimal? ClientPrice     = null,
        decimal? ClientLineTotal = null,
        string? ClientGpid       = null,
        decimal? BidRefAmt       = null,
        // Status: null means no status has been set. Use WoApprovalStatus constants
        // for known values; StatusCss() maps these to CSS modifier classes.
        string? StatusBusiness   = null,
        string? StatusCustomer   = null,
        string? StatusInvestor   = null,
        // ── Work order header fields ──────────────────────────────────────────
        string? WorkOrderId      = null,
        string? Category         = null,
        string? Vendor           = null,
        string? BilledDate       = null,
        // CollapsedHint: pre-formatted summary shown when the group is collapsed.
        // TODO: compute from aggregated line-item data rather than storing in the VM.
        string? CollapsedHint    = null,
        // ── Subtotal / Total fields ───────────────────────────────────────────
        // SubtotalLabel: display string for the row (typically "WO {WorkOrderId}").
        string? SubtotalLabel            = null,
        decimal? VendorUnitPriceSubtotal = null,
        decimal? VendorLineTotalSubtotal = null,
        decimal? ClientPriceSubtotal     = null,
        decimal? ClientLineTotalSubtotal = null
    );

    /// <summary>
    /// Property-level P&amp;P summary panel data.
    /// Replace BuildSummary() with an API/service call.
    /// TODO: PendingApprovals should become int once API-wired; format the display
    /// string in the template rather than storing a pre-formatted string.
    /// </summary>
    private sealed record FinancialSummaryVm(
        string PropertyAddress,
        decimal PandPTotal,
        decimal PandPPrior,
        decimal PandPCurrent,
        decimal HudReimbNonPandP,
        decimal NonHudReimb,
        decimal Total,
        decimal Receivables,
        decimal Payables,
        string PendingApprovals
    );

    private sealed class BreadcrumbItem
    {
        public string Text { get; set; } = "";
        public string? Url { get; set; }
        public bool Disabled { get; set; }
    }

    // ──────────────────────────────────────────────────────────────────────────────
    // Status constants
    // ──────────────────────────────────────────────────────────────────────────────

    /// <summary>
    /// Canonical approval status strings shared between mock data and StatusCssMap.
    /// API responses are expected to return these same strings (any casing —
    /// StatusCssMap uses OrdinalIgnoreCase for resilience).
    /// </summary>
    private static class WoApprovalStatus
    {
        public const string Approved            = "Approved";
        public const string ApprAllowable       = "Appr. allowable";
        public const string UnderReview         = "Under review";
        public const string NotRequired         = "Not required";
        public const string PendingNotSubmitted = "Pend. not sub.";
    }

    // ──────────────────────────────────────────────────────────────────────────────
    // State
    // ──────────────────────────────────────────────────────────────────────────────

    private readonly HashSet<string> _collapsedGroups = new(StringComparer.Ordinal);

    private readonly FinancialSummaryVm _summary = BuildSummary();

    private readonly List<FinancialRowVm> _allRows = BuildAllRows();

    private readonly List<BreadcrumbItem> _breadcrumb =
    [
        new BreadcrumbItem { Text = "Properties", Url = "/properties/portfolio" },
        new BreadcrumbItem { Text = "Financials", Url = "/properties/financials" },
        new BreadcrumbItem { Text = "5426 Trinity St", Disabled = true }
    ];

    // ──────────────────────────────────────────────────────────────────────────────
    // Computed
    // ──────────────────────────────────────────────────────────────────────────────

    /// <summary>
    /// Rows visible in the current collapse state.
    /// WO headers and the property total are always shown.
    /// Line items and subtotals are hidden when their work order group is collapsed.
    /// </summary>
    private IEnumerable<FinancialRowVm> VisibleRows =>
        _allRows.Where(r =>
            r.Kind == FinancialRowKind.WorkOrderHeader ||
            r.Kind == FinancialRowKind.Total           ||
            r.WorkOrderId is null                      ||
            !_collapsedGroups.Contains(r.WorkOrderId));

    // ──────────────────────────────────────────────────────────────────────────────
    // Event handlers
    // ──────────────────────────────────────────────────────────────────────────────

    private void ToggleWorkOrder(string workOrderId)
    {
        if (!_collapsedGroups.Remove(workOrderId))
            _collapsedGroups.Add(workOrderId);
    }

    private bool IsCollapsed(string? workOrderId) =>
        workOrderId is not null && _collapsedGroups.Contains(workOrderId);

    // ──────────────────────────────────────────────────────────────────────────────
    // Formatting helpers
    // ──────────────────────────────────────────────────────────────────────────────

    private static readonly CultureInfo _usCulture = CultureInfo.GetCultureInfo("en-US");

    private static string Fmt(decimal value)    => value.ToString("C", _usCulture);
    private static string FmtOpt(decimal? value) => value.HasValue ? Fmt(value.Value) : "—";

    // ── Status rendering ─────────────────────────────────────────────────────────

    /// <summary>
    /// Maps known approval status strings to CSS modifier classes.
    /// OrdinalIgnoreCase so API casing variations (e.g. "approved" vs "Approved")
    /// are handled without extra normalisation at the call site.
    /// To add a new status: add a constant to WoApprovalStatus, add a CSS rule for
    /// the modifier class, and add an entry here.
    /// </summary>
    private static readonly Dictionary<string, string> StatusCssMap =
        new(StringComparer.OrdinalIgnoreCase)
        {
            [WoApprovalStatus.Approved]            = "ft-status ft-status--approved",
            [WoApprovalStatus.ApprAllowable]       = "ft-status ft-status--appr-allowable",
            [WoApprovalStatus.UnderReview]         = "ft-status ft-status--under-review",
            [WoApprovalStatus.NotRequired]         = "ft-status ft-status--not-required",
            [WoApprovalStatus.PendingNotSubmitted] = "ft-status ft-status--pending",
        };

    private static string StatusCss(string? status) =>
        string.IsNullOrWhiteSpace(status)
            ? "ft-status ft-status--empty"
            : StatusCssMap.TryGetValue(status, out var css) ? css : "ft-status ft-status--neutral";

    private static string StatusText(string? status) =>
        string.IsNullOrWhiteSpace(status) ? "—" : status;

    // ──────────────────────────────────────────────────────────────────────────────
    // Mock data — replace BuildAllRows() + BuildSummary() with API/service calls
    // ──────────────────────────────────────────────────────────────────────────────

    private static FinancialSummaryVm BuildSummary() => new(
        PropertyAddress : "5426 Trinity St, Philadelphia PA 19143",
        PandPTotal      : 5_000.00m,
        PandPPrior      : 4_833.10m,
        PandPCurrent    :   166.90m,
        HudReimbNonPandP:     0.00m,
        NonHudReimb     :   252.73m,
        Total           : 22_774.89m,
        Receivables     : 15_086.89m,
        Payables        :  9_696.73m,
        PendingApprovals: "3 items pending"
    );

    private static List<FinancialRowVm> BuildAllRows()
    {
        const string Wo1 = "463456003-LMR";
        const string Wo2 = "463456003-BDE";

        return
        [
            // ── Work Order 1: Lawn Maintenance ───────────────────────────────────
            new FinancialRowVm(
                Kind          : FinancialRowKind.WorkOrderHeader,
                WorkOrderId   : Wo1,
                Category      : "Lawn Maintenance",
                Vendor        : "Leyland Property Management",
                BilledDate    : "4/3/2026",
                CollapsedHint : "2 items · vendor $1,135.00 / client $1,235.00"
            ),
            new FinancialRowVm(
                Kind           : FinancialRowKind.LineItem,
                WorkOrderId    : Wo1,
                LineItem       : "Lawn Maintenance",
                Description    : "Full mow, edge, and blow service — 1,362 SqFt",
                QtyDisplay     : "1",
                Uom            : "EA",
                VendorUnitPrice: 55.00m,
                VendorLineTotal: 55.00m,
                VendorGpid     : "1",
                ClientPrice    : 95.00m,
                ClientLineTotal: 95.00m,
                ClientGpid     : "3",
                BidRefAmt      : 95.00m,
                StatusBusiness : WoApprovalStatus.ApprAllowable,
                StatusCustomer : WoApprovalStatus.NotRequired,
                StatusInvestor : WoApprovalStatus.NotRequired
            ),
            new FinancialRowVm(
                Kind           : FinancialRowKind.LineItem,
                WorkOrderId    : Wo1,
                LineItem       : "Lawn Maintenance — 12 Recuts",
                Description    : "12 recurring lawn maintenance cuts",
                QtyDisplay     : "12",
                Uom            : "EA",
                VendorUnitPrice: 1_080.00m,
                VendorLineTotal: 1_080.00m,
                VendorGpid     : "1",
                ClientPrice    : 1_140.00m,
                ClientLineTotal: 1_140.00m,
                ClientGpid     : "3",
                BidRefAmt      : 1_140.00m,
                StatusBusiness : WoApprovalStatus.Approved,
                StatusCustomer : WoApprovalStatus.NotRequired,
                StatusInvestor : WoApprovalStatus.NotRequired
            ),
            new FinancialRowVm(
                Kind                    : FinancialRowKind.Subtotal,
                WorkOrderId             : Wo1,
                SubtotalLabel           : "WO 463456003-LMR",
                VendorUnitPriceSubtotal : 1_135.00m,
                VendorLineTotalSubtotal : 1_135.00m,
                ClientPriceSubtotal     : 1_235.00m,
                ClientLineTotalSubtotal : 1_235.00m
            ),

            // ── Work Order 2: Boarding / Door / Exterior ─────────────────────────
            new FinancialRowVm(
                Kind          : FinancialRowKind.WorkOrderHeader,
                WorkOrderId   : Wo2,
                Category      : "Boarding / Door / Exterior",
                Vendor        : "Leyland Property Management",
                BilledDate    : "3/3/2026",
                CollapsedHint : "3 items · vendor $1,174.00 / client $1,566.16"
            ),
            new FinancialRowVm(
                Kind           : FinancialRowKind.LineItem,
                WorkOrderId    : Wo2,
                LineItem       : "Boarding",
                Description    : "Board — Window (74 units)",
