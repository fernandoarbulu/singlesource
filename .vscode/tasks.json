{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run: Blazor (watch)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "watch",
        "run",
        "--launch-profile",
        "http",
        "--project",
        "${workspaceFolder}/SinglesourceApp.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "dotnet-watch",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*(Building|watch)\\b.*",
          "endsPattern": "^.*Now listening on:.*"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    }
  ]
}
